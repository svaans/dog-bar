# Copia a .env.local en desarrollo o configura en Render → Environment.

# --- Obligatorio en producción (personal, backup, CSV, admin carta) ---
# Sin esto en NODE_ENV=production el panel del personal queda bloqueado (401).
# Ejemplo fácil de recordar para pruebas; en internet usa otra más larga.
STAFF_ORDER_KEY=meraki-equipo

# --- URL pública de la app (QRs, Open Graph). En Render: https://tu-servicio.onrender.com ---
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# --- Zona horaria del local (historial / CSV por día) ---
# RESTAURANT_TZ=Europe/Madrid

# --- Pedidos: uno de estos modos ---

# Por defecto (o vacío): JSON en disco ./data/orders.json (en Render se pierde al redeploy salvo disco persistente).
# ORDER_STORAGE=

# SQLite en archivo (mejor con disco persistente montado en ./data).
# ORDER_STORAGE=sqlite
# SQLITE_PATH=/data/orders.db

# Supabase (recomendado en Render sin disco): crea tabla con supabase/migrations/*.sql
# ORDER_STORAGE=supabase
# SUPABASE_URL=https://xxxx.supabase.co
# O bien: NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (service_role, nunca en el cliente)
